{
  "expo": {
    "name": "sousChef",
    "slug": "souschef",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.keiranworrell.souschef"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f97316"
      },
      "package": "com.keiranworrell.souschef"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f97316"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "scheme": "souschef",
    "owner": "keiranworrell",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "eec4bb25-774c-4525-98eb-b97fa6cd50ba"
      }
    }
  }
}
