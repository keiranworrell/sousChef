# ─── Database ─────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-2
AWS_ACCOUNT_ID=123456789012

# ─── Cognito ──────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=eu-west-2_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── S3 / CloudFront ──────────────────────────────────────────────────────────
S3_IMAGES_BUCKET=souschef-images-prod
CLOUDFRONT_DOMAIN=https://cdn.souschef.app

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Retrieved from AWS Secrets Manager at runtime — do not set directly in Lambda
ANTHROPIC_API_KEY=sk-ant-...

# ─── API ──────────────────────────────────────────────────────────────────────
API_BASE_URL=https://api.souschef.app
