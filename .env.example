# ─── Database ─────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string.
# Retrieve from: Neon dashboard → your project → Connection Details
# In production this is stored in AWS Secrets Manager, not here.
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# ─── AWS ──────────────────────────────────────────────────────────────────────
# Used by Lambda functions at runtime (injected by the Lambda execution role).
# Not needed locally unless running Lambda handlers directly.
AWS_REGION=eu-west-2

# ─── AI ───────────────────────────────────────────────────────────────────────
# Anthropic API key for all agent calls.
# Retrieve from: https://console.anthropic.com/settings/keys
# In production this is stored in AWS Secrets Manager.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Web app ──────────────────────────────────────────────────────────────────
# Base URL of the API Gateway endpoint. Used by the Next.js app.
NEXT_PUBLIC_API_URL=https://api.souschef.app
